# Livepeer Video Gateway — env vars consumed by docker-compose.yml.
# Copy to `.env` and fill in.
#
# Default values (in compose) are dev-only. For production, set
# everything below.

# ── Postgres ────────────────────────────────────────────────────────
POSTGRES_DB=video_gateway
POSTGRES_USER=video_gateway
POSTGRES_PASSWORD=please-change-me
POSTGRES_HOST_PORT=5432

# ── Gateway HTTP ────────────────────────────────────────────────────
BASE_URL=https://api.example.com
PUBLIC_SITE_URL=https://example.com
PUBLIC_PORTAL_URL=https://portal.example.com
ALLOWED_ORIGINS=https://example.com,https://portal.example.com,https://admin.example.com
LOG_LEVEL=info
GATEWAY_HOST_PORT=4000

# ── SaaS shell auth — REQUIRED in production ───────────────────────
ADMIN_TOKEN=
API_KEY_HASH_PEPPER=
IP_HASH_PEPPER=
METRICS_TOKEN=
SESSION_TTL_HOURS=24

# ── Email (optional — without this, verification + key emails log to
#    stdout instead of sending) ─────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=Livepeer Video Gateway <noreply@example.com>

# ── MinIO / S3 (VOD ingest object store + live HLS output) ────────
# MinIO is the S3-compatible store. The compose stack brings it up
# alongside the gateway and a one-shot bootstrap container creates
# the bucket and the gateway's long-lived access key. Live sessions
# additionally mint per-session credentials via MinIO STS AssumeRole,
# scoped to live-out/<api>/<sess>/* by inline policy.
MINIO_ROOT_USER=minio_root
MINIO_ROOT_PASSWORD=please-change-me
MINIO_HOST_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_REGION=us-east-1
S3_BUCKET=lvp-video-ingest
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=video-gateway
S3_SECRET_ACCESS_KEY=please-change-me
S3_PRESIGN_TTL_SECONDS=3600

# ── Livepeer plumbing ──────────────────────────────────────────────
# The gateway is on-chain only: resolver + payer daemons are required
# for /v1/* traffic.
REGISTRY_REFRESH_INTERVAL_MS=60000

# ── /v1/* rate limit ──────────────────────────────────────────────
# Per-API-key token bucket. burst = max tokens accumulated;
# per_minute = refill rate.
V1_RATE_LIMIT_PER_MINUTE=60
V1_RATE_LIMIT_BURST=30

# ── Livepeer daemons (only used with `docker compose --profile livepeer up`) ──
CHAIN_RPC=
CHAIN_ID=42161
CONTROLLER_ADDRESS=0xD8E8328501E9645d16Cf49539efC04f734606ee4
AI_SERVICE_REGISTRY_ADDRESS=
ROUND_POLL_INTERVAL=120s
CACHE_MANIFEST_TTL=5m
MANIFEST_MAX_BYTES=1048576
MANIFEST_FETCH_TIMEOUT=5s
MAX_STALE=30m
REGISTRY_LOG_LEVEL=info
REGISTRY_LOG_FORMAT=json
REGISTRY_METRICS_PORT=9095

# ── Payer keystore ─────────────────────────────────────────────────
# Path on the host that contains keystore.json + keystore-password.
LIVEPEER_KEYSTORE_DIR=./.dev/keystore

# ── Daemon image tags ──────────────────────────────────────────────
LIVEPEER_REGISTRY_DAEMON_TAG=v1.3.1
LIVEPEER_PAYER_DAEMON_TAG=v1.3.1
MINIO_IMAGE_TAG=latest
GATEWAY_TAG=dev

# ── Transcode capability defaults ─────────────────────────────────
# Capability identifiers the gateway expects on the network. Override
# only if the supply side advertises different names.
ABR_CAPABILITY=video:transcode.abr
# Live transcode capability id + offering label per the upstream spec:
# orchs advertise video:transcode.live + offering "gateway-ingest" +
# mode live-session-gateway-ingest@v0.
LIVE_CAPABILITY=video:transcode.live
LIVE_GATEWAY_INGEST_OFFERING=gateway-ingest

# ── live-session-gateway-ingest@v0 tuning ────────────────────────
# Idle timeout the gateway requests from the broker on session open;
# the broker may apply its own floor/ceiling on top of this.
LIVE_IDLE_TIMEOUT_SECS=120
# Background reconciler cadence. 0 disables the loop and falls back to
# on-GET reconciliation only.
LIVE_RECONCILE_INTERVAL_SECS=30
# Auto-topup triggers when broker-reported runway falls below this
# threshold; the next topup envelope buys roughly LIVE_TOPUP_FUND_SECS
# worth of additional runway.
LIVE_TOPUP_RUNWAY_THRESHOLD_SECS=60
LIVE_TOPUP_FUND_SECS=60

# ── Live RTMP ingest (gateway-owned listener) ────────────────────
# Public TCP port the gateway listens on for customer RTMP pushes.
# Set to 0 to disable live ingest entirely.
LIVE_RTMP_PORT=1935
# Public base URL for HLS playback (CDN or MinIO public endpoint).
# Empty falls back to building a URL from S3_PUBLIC_ENDPOINT.
LIVE_PLAYBACK_BASE_URL=
# Lifetime of the per-session STS credentials the gateway mints for
# the runner (PutObject scope only).
LIVE_S3_CREDENTIAL_TTL_HOURS=4
